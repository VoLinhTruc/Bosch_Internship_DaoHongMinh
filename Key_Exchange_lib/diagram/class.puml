@startuml class

package "keyexchange_library" {

  class KeyExchangeService {
    +anchor_idx: int
    -factory_private_key: bytes | None
    -secoc_key: bytes | None
    -iv: bytes | None

    -state: KeyExchangeState
    -current_step: KeyExchangeStep

    -seed: bytes | None
    -signature: bytes | None

    -master_public_key: bytes | None
    -master_private_key: bytes | None
    -anchor_public_key: bytes | None

    -shared_secret: bytes | None
    -truncated_shared_key: bytes | None
    -encrypted_key: bytes | None

    -last_request: bytes | None
    -last_response: bytes | None
    -last_error: Exception | None

    +KeyExchangeService(anchor_idx)

    +set_anchor_idx(anchor_idx: int): None
    +set_factory_private_key(private_key_blob: bytes): None
    +set_secoc_key(secoc_key: bytes): None
    +set_iv(iv: bytes): None

    +start(): bytes
    +handle_response(response: bytes): bytes | None
    +reset(): None

    +status(): KeyExchangeState
    +step(): KeyExchangeStep

    +is_running(): bool
    +is_complete(): bool
    +is_failed(): bool

    +get_encrypted_key(): bytes | None
    +get_last_request(): bytes | None
    +get_last_response(): bytes | None
    +get_last_error(): Exception | None

    -build_request_for_current_step(): bytes
    -process_response_for_current_step(response: bytes): None

    -generate_signature(seed: bytes): bytes
    -generate_master_keypair(): None
    -derive_shared_secret(anchor_public_key: bytes): bytes
    -hash_and_truncate_shared_secret(shared_secret: bytes): bytes
    -encrypt_secoc_key(): bytes

    -require_configured_material(): None
    -set_failed(error: Exception | str): None
  }

  enum KeyExchangeStep {
    IDL
    DEFAULT_SESSION
    EXTENDED_SESSION
    REQUEST_SEED
    SECURITY_UNLOCK
    PUBLIC_KEY_EXCHANGE
    DELIVER_ENCRYPTED_KEY
    COMPLETE
    FAILED
  }

  enum KeyExchangeState {
    IDLE
    RUNNING
    COMPLETE
    FAILED
  }
}

KeyExchangeService --> KeyExchangeStep
KeyExchangeService --> KeyExchangeState

@enduml