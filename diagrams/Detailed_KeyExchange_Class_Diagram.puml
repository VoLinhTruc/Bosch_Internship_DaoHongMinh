@startuml DetailedClassDiagram(structure)
skinparam classAttributeIconSize 0

namespace service {

class Service {
    + Service(databrokerAddress_Public : DataBrokerAddressType, databrokerAddress_Private : DataBrokerAddressType)
    + ~Service()
    + Run() : void
    + Stop() : void
    + OnStart() : void
    + OnStop() : void
    + Init() : void
    + CheckConnection() : void

    # mDatabrokerAddress_Public : DataBrokerAddressType
    # mDatabrokerAddress_Private : DataBrokerAddressType
    # mPort : PortType
    # mIp : IpType
    # mIsRunning : bool = false
    # mStopWaitMutex : mutex
    # mStopWaitCV : condition_variable
    # mStartFlagService : atomic<EServiceState>
}

class KeyExchange {
    - mPathValueMap : map<string, kuksaclientapi::DataType>

    - mRes : vector<unsigned char>
    - mDefaultSession : vector<unsigned char>
    - mExtendSession : vector<unsigned char>
    - mReqSecAccSeedInCar1 : vector<unsigned char>
    - mResSecAccSeedInCar1_UDSservice : vector<unsigned char>
    - mReqSecUnlockInCar1 : vector<unsigned char>
    - mRS_Signature : vector<unsigned char>
    - mKeyExchangeDiag1 : vector<unsigned char>
    - mKeyExchangeDiag2 : vector<unsigned char>
    - mPrivateKeyBlob : vector<unsigned char>
    - mECDH_pK_Anchor : vector<unsigned char>
    - mECDH_pK_Master : vector<unsigned char>
    - mECDH_sK_Master : vector<unsigned char>
    - mShareKey : vector<unsigned char>
    - mEncryptedKeyVec : vector<unsigned char>

    - pool : unique_ptr<ThreadPool>

    - mKey : uint8_t[96]
    - mIV : uint8_t[16]
    - mEncryptedKey : uint8_t[96]

    - ANCHOR_DELAY_MS : uint16_t = 500
    - mAnchorIdx : msg::AnchorIdxType
    - mCheckFF : int
    - mStopFlagKeyExchange : bool
    - mStopFlagRanging : bool
    - mStateMachineStep : msg::KeyExchangeStateType
    - mStrAnchor : string = "Anchor"
    - mStopFlag : atomic<bool>
    - mStart : atomic<bool>
    - mRunning : atomic<bool>
    - mNextState : msg::KeyExchangeStateType
    - mSecKeyIsExchanged : atomic<bool>
    - mDistances : uint32_t[4]
    - mRetryKeyExchangecnt : uint8_t = 0

    + KeyExchange(databrokerAddr_Public : const string&, databrokerAddr_Private : const string&)
    + ~KeyExchange()
    + OnStart() : void
    + Init() : void

    - InitializeParameters() : void
    - KeyExchangeAnchor() : void
    - InitDataService() : void
    - EnqueueMessage(keyExchangeStatus : const msg::KeyExchangeStateType) : void
    - FunctionTest_StateMachineAnchorSecOCKeyExchange() : void
    - StateMachineAnchorSecOCKeyExchange() : void
}

enum EServiceState {
    START
    STOP
    RESET
    ERROR
}

enum KeyExchangeCmd {
    Start
    Stop
}

enum AnchorIdx {
    Anchor2 = 2
    Anchor3
    Anchor4
    Anchor5
    NotDefined
}

enum SdvRange {
    Range0
    Range1
}

Service ..> "kuksaclientapi::CheckConnection()" : uses
Service ..> EServiceState
KeyExchange --|> Service

KeyExchange -- KeyExchangeCmd
KeyExchange -- AnchorIdx
KeyExchange -- SdvRange
KeyExchange -- ThreadPool
KeyExchange ..> "msg::AnchorIdxType" : uses
KeyExchange ..> "msg::KeyExchangeStateType" : uses
KeyExchange ..> "kuksaclientapi::DataType" : uses

}

@enduml