@startuml RelationBetweenClasses
hide empty members

namespace service {
  class "Service" as Svc

  class "KeyExchange" as KE {
    + KeyExchange(databrokerAddr_Public : string, databrokerAddr_Private : string)
    + ~KeyExchange()
    + OnStart() : void
    + Init() : void

    - InitializeParameters() : void
    - KeyExchangeAnchor() : void
    - InitDataService() : void
    - EnqueueMessage(keyExchangeStatus) : void
    - FunctionTest_StateMachineAnchorSecOCKeyExchange() : void
    - StateMachineAnchorSecOCKeyExchange() : void
  }
}

package "cryptography::keyexchange" {
  class "CryptoKeyExchange" as CKX <<utility>>
}

class "AES128" as AES128 <<utility>>
class "Logger" as Logger <<utility>>
class "ThreadPool" as ThreadPool
class "Message Handler" as MsgHandler <<utility>>
class "CAN TP" as CanTp <<utility>>
class "Data Broker / Kuksa API" as Kuksa <<utility>>
class "utils" as Utils <<utility>>

package "ijob" {
  interface "IJob" as IJob
  class "Job" as Job
  class "RecurringJob" as RecurringJob
}

package "uds" {
  enum "uds_sid_t" as UdsSid
  enum "uds_nrc_t" as UdsNrc
}

enum "KeyExchangeCmd" as KeyExchangeCmd
enum "AnchorIdx" as AnchorIdx

KE --|> Svc
KE -- KeyExchangeCmd
KE -- AnchorIdx

KE --> ThreadPool : manages worker tasks
KE ..> MsgHandler : exchanges status/messages
KE ..> CanTp : transports diagnostic frames
KE ..> Kuksa : updates service state
KE ..> CKX : performs crypto operations
KE ..> AES128 : encrypts payload
KE ..> Logger : logs events
KE ..> Utils : configuration/helpers
KE ..> UdsSid : checks SID values
KE ..> UdsNrc : checks NRC values

ThreadPool ..> Job : executes
ThreadPool ..> RecurringJob : executes recurring jobs
ThreadPool ..> IJob : generic job interface
Job --|> IJob
RecurringJob --|> Job

CKX ..> AES128 : symmetric crypto support
CKX ..> Logger : logs

MsgHandler ..> Kuksa : broker access
CanTp ..> Kuksa : CAN signal transport via broker
CanTp ..> ThreadPool : dependency
CanTp ..> Logger : logs

Svc ..> Kuksa : connection check
Svc ..> Logger : logs
Svc ..> Utils : address/argument helpers

note right of KE
  High-level responsibilities:
  - manage key exchange workflow
  - coordinate state machine
  - communicate with anchor/ECU
  - invoke cryptographic operations
  - update external service status
end note

note right of CKX
  High-level crypto services:
  - ECDH key generation
  - shared key derivation
  - ECDSA signing
  - hash-based key processing
end note

note bottom of ThreadPool
  ThreadPool schedules and runs jobs
  defined by the ijob module
end note

note bottom of UdsNrc
  UDS enums provide protocol constants
  used by KeyExchange state handling
end note

@enduml